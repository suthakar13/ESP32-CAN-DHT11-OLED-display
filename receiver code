#include <SPI.h>
#include <mcp2515.h>
#include <Wire.h>
#include <Adafruit_SSD1306.h>

// OLED settings
#define SCREEN_WIDTH 128
#define SCREEN_HEIGHT 64
#define OLED_RESET -1

Adafruit_SSD1306 display(SCREEN_WIDTH, SCREEN_HEIGHT, &Wire, OLED_RESET);

// CAN setup
struct can_frame canMsg;
struct MCP2515 mcp2515(5); // CS pin GPIO 5

#define CAN_RX_ID  0x036
#define CAN_ACK_ID 0x037

void setup()
{
  Serial.begin(115200);

  // I2C init (important for ESP32)
  Wire.begin(21, 22);

  // OLED init
  if (!display.begin(SSD1306_SWITCHCAPVCC, 0x3C)) {
    Serial.println("OLED init failed");
    while (1);
  }

  display.clearDisplay();
  display.setTextColor(WHITE);

  // CAN init
  SPI.begin();
  mcp2515.reset();
  mcp2515.setBitrate(CAN_500KBPS, MCP_8MHZ);
  mcp2515.setNormalMode();

  Serial.println("Receiver Ready");
}

void loop()
{
  if (mcp2515.readMessage(&canMsg) == MCP2515::ERROR_OK)
  {
    if (canMsg.can_id == CAN_RX_ID && canMsg.can_dlc >= 4)
    {
      // Decode temperature
      int tempInt = (canMsg.data[0] << 8) | canMsg.data[1];
      float temperatureC = tempInt / 100.0;

      // Decode humidity
      int humInt = (canMsg.data[2] << 8) | canMsg.data[3];
      float humidity = humInt / 100.0;

      // Serial output
      Serial.print("Temp: ");
      Serial.print(temperatureC);
      Serial.print(" °C | Humidity: ");
      Serial.print(humidity);
      Serial.println(" %");

      // OLED display
      display.clearDisplay();

      display.setTextSize(1);
      display.setCursor(10, 5);
      display.print("Temperature");

      display.setTextSize(2);
      display.setCursor(10, 18);
      display.print(temperatureC);
      display.print(" C");

      display.setTextSize(1);
      display.setCursor(10, 42);
      display.print("Humidity");

      display.setTextSize(2);
      display.setCursor(10, 52);
      display.print(humidity);
      display.print(" %");

      display.display();

      // Send ACK (separate message)
      struct can_frame ackMsg;
      ackMsg.can_id  = CAN_ACK_ID;
      ackMsg.can_dlc = 0;
      mcp2515.sendMessage(&ackMsg);

      Serial.println("ACK sent");
    }
  }
}
